# .env.example — reference for required environment variables.
# Copy to .env (gitignored) for local development, OR set the same
# variables in the Vercel dashboard under Project Settings → Environment
# Variables for production + preview deployments.

# Stripe secret key — used by middleware.js to verify that a /success
# visit corresponds to a real, paid Checkout Session.
# Get from: https://dashboard.stripe.com/apikeys  (Developers → API keys)
#   - Use the LIVE key (`sk_live_...`) for Production
#   - Use the TEST key (`sk_test_...`) for Preview + local testing
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
